{
  "name": "agent-sessions-manager",
  "version": "0.1.0",
  "description": "Unified session manager for coding agents (Claude Code, OpenCode, Codex, Cursor)",
  "type": "module",
  "bin": {
    "asm": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "prepare": "test -d node_modules/tsup && tsup || true",
    "prepublishOnly": "tsup"
  },
  "keywords": ["agent", "sessions", "claude-code", "opencode", "codex", "cursor", "cli", "tui", "session-manager"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xctrlfly/asm.git"
  },
  "homepage": "https://github.com/xctrlfly/asm#readme",
  "bugs": {
    "url": "https://github.com/xctrlfly/asm/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.0.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
